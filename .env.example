# Database connection — use a MySQL connection string
# Local dev: install MySQL or use a cloud provider (Aiven, TiDB Cloud, PlanetScale)
# Production: set this in Vercel environment variables
DATABASE_URL="mysql://user:password@host:3306/techniqs_burn"

# Secret token used to authenticate the /api/cleanup cron job
# Generate one with: openssl rand -hex 32
CLEANUP_SECRET="generate-a-random-token"
